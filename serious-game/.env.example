# Azure OpenAI configuration (used by server.ts)
# Either use these AZURE_OPENAI_* names or the lowercase names in .env.local.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-04-01-preview

# Prompt file locations (optional)
ATTACKER_PROMPT_PATH=prompts/attacker_prompt.md
GENUINE_PROMPT_PATH=prompts/genuine_prompt.md

# Backend server configuration (used by frontend to communicate with backend)
VITE_BACKEND_URL=http://localhost:3001
